generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STORE
  PRODUCTION
  SALES
  MANAGEMENT
}

enum MaterialRequestStatus {
  PENDING
  PARTIALLY_ISSUED
  FULFILLED
  CANCELLED
  REJECTED
}

enum RawMaterialStockMovementType {
  RECEIVE
  ISSUE
  ADJUSTMENT
}

enum FinishedProductStockMovementType {
  RECEIVE_FROM_PRODUCTION
  SALE
  RETURN
  DAMAGED
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
  CREDIT
}

enum CustomerType {
  INDIVIDUAL
  RETAILER
}

enum SalesReturnDisposition {
  RETURN_TO_STOCK
  DAMAGED
}

enum PosSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ProductionMaterialStockMovementType {
  RECEIVE_FROM_STORE
  CONSUME
  WASTE
  ADJUSTMENT
}

enum ProductionWasteType {
  DAMAGED
  RETURNED_TO_PRODUCTION
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         Role      @default(STORE)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?

  createdBy                   User?                             @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers                User[]                            @relation("UserCreatedBy")
  auditLogs                   AuditLog[]                        @relation("AuditActor")
  createdMaterialBatches      RawMaterialBatch[]                @relation("RawMaterialBatchCreatedBy")
  createdMaterialReceipts     RawMaterialReceipt[]              @relation("RawMaterialReceiptCreatedBy")
  materialRequests            MaterialRequest[]                 @relation("MaterialRequestRequestedBy")
  issuedMaterialRequests      MaterialRequest[]                 @relation("MaterialRequestIssuedBy")
  materialRequestIssues       MaterialRequestIssue[]            @relation("MaterialRequestIssueIssuedBy")
  stockMovements              RawMaterialStockMovement[]        @relation("StockMovementActor")
  productionRuns              ProductionRun[]                   @relation("ProductionRunCreatedBy")
  productionWaste             ProductionWaste[]                 @relation("ProductionWasteCreatedBy")
  productionMaterialBatches   ProductionMaterialStockBatch[]    @relation("ProductionMaterialBatchCreatedBy")
  productionMaterialMovements ProductionMaterialStockMovement[] @relation("ProductionMaterialMovementActor")
  salesProductBatches         SalesProductBatch[]               @relation("SalesProductBatchCreatedBy")
  salesProductMovements       SalesProductStockMovement[]       @relation("SalesProductMovementActor")
  sales                       Sale[]                            @relation("SaleCreatedBy")
  salesReturns                SalesProductReturn[]              @relation("SalesReturnCreatedBy")
  createdRetailers            Retailer[]                        @relation("RetailerCreatedBy")
  retailerPayments            RetailerPayment[]                 @relation("RetailerPaymentCreatedBy")
  posSessions                 PosSession[]                      @relation("PosSessionCreatedBy")
  posTerminals                PosTerminal[]                     @relation("PosTerminalCreatedBy")
  expenses                    Expense[]                         @relation("ExpenseCreatedBy")
  voidedExpenses              Expense[]                         @relation("ExpenseVoidedBy")

  @@index([role])
  @@index([isActive])
}

// --- Phase 2: Admin master data ---

model Unit {
  id           String   @id @default(cuid())
  name         String
  abbreviation String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rawMaterials RawMaterial[]
  products     Product[]
  recipeItems  RecipeItem[]

  @@index([isActive])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches  RawMaterialBatch[]
  receipts RawMaterialReceipt[]

  @@index([isActive])
}

model RawMaterial {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  baseUnitId  String
  unitCost    Decimal? @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baseUnit            Unit                              @relation(fields: [baseUnitId], references: [id], onDelete: Restrict)
  recipeItems         RecipeItem[]
  batches             RawMaterialBatch[]
  receipts            RawMaterialReceipt[]
  stockMovements      RawMaterialStockMovement[]
  materialRequests    MaterialRequest[]
  productionBatches   ProductionMaterialStockBatch[]
  productionMovements ProductionMaterialStockMovement[]
  productionRunUsages ProductionRunMaterialUsage[]

  @@index([isActive])
  @@index([baseUnitId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  size        String   @default("")
  description String?
  unitId      String
  unitPrice   Decimal? @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit                Unit                        @relation(fields: [unitId], references: [id], onDelete: Restrict)
  recipe              Recipe?
  productionRuns      ProductionRun[]
  productionWaste     ProductionWaste[]
  salesBatches        SalesProductBatch[]
  salesStockMovements SalesProductStockMovement[]
  saleItems           SaleItem[]
  salesReturns        SalesProductReturn[]
  posSessionItems     PosSessionItem[]

  @@unique([name, size])
  @@index([isActive])
  @@index([unitId])
}

model Recipe {
  id            String   @id @default(cuid())
  productId     String   @unique
  yieldQuantity Int      @default(1)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   RecipeItem[]
}

model RecipeItem {
  id            String  @id @default(cuid())
  recipeId      String
  rawMaterialId String
  quantity      Decimal @db.Decimal(14, 3)
  unitId        String

  recipe      Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([recipeId, rawMaterialId])
  @@index([rawMaterialId])
  @@index([unitId])
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@index([isActive])
}

model Expense {
  id            String        @id @default(cuid())
  categoryId    String
  amount        Decimal       @db.Decimal(14, 2)
  incurredAt    DateTime      @db.Date
  vendor        String?
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  createdAt    DateTime  @default(now())
  createdById  String?
  // Expenses are voided, never deleted, so the books keep their trail.
  voidedAt     DateTime?
  voidedById   String?
  voidReason   String?

  category  ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  voidedBy  User?           @relation("ExpenseVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)

  @@index([incurredAt])
  @@index([categoryId])
  @@index([createdById])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// --- Phase 3: Store inventory and production requests ---

model RawMaterialBatch {
  id                String   @id @default(cuid())
  rawMaterialId     String
  supplierId        String?
  batchNumber       Int
  batchDate         DateTime @db.Date
  quantityReceived  Decimal  @db.Decimal(14, 3)
  quantityRemaining Decimal  @db.Decimal(14, 3)
  unitCost          Decimal? @db.Decimal(14, 2)
  receivedAt        DateTime
  reference         String?
  notes             String?
  createdAt         DateTime @default(now())
  createdById       String?

  rawMaterial       RawMaterial                    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  supplier          Supplier?                      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy         User?                          @relation("RawMaterialBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  receipts          RawMaterialReceipt[]
  movements         RawMaterialStockMovement[]
  issues            MaterialRequestIssue[]
  productionBatches ProductionMaterialStockBatch[] @relation("ProductionStockSourceStoreBatch")

  @@unique([rawMaterialId, batchNumber])
  @@unique([rawMaterialId, batchDate])
  @@index([batchDate])
  @@index([rawMaterialId, receivedAt])
  @@index([supplierId])
  @@index([quantityRemaining])
}

model RawMaterialReceipt {
  id            String   @id @default(cuid())
  rawMaterialId String
  batchId       String
  supplierId    String?
  quantity      Decimal  @db.Decimal(14, 3)
  unitCost      Decimal? @db.Decimal(14, 2)
  receivedAt    DateTime
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  createdById   String?

  rawMaterial RawMaterial                @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  batch       RawMaterialBatch           @relation(fields: [batchId], references: [id], onDelete: Restrict)
  supplier    Supplier?                  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy   User?                      @relation("RawMaterialReceiptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  movements   RawMaterialStockMovement[]

  @@index([rawMaterialId, receivedAt])
  @@index([batchId])
  @@index([supplierId])
  @@index([createdById])
}

model RawMaterialStockMovement {
  id            String                       @id @default(cuid())
  rawMaterialId String
  batchId       String
  receiptId     String?
  type          RawMaterialStockMovementType
  quantity      Decimal                      @db.Decimal(14, 3)
  balanceAfter  Decimal                      @db.Decimal(14, 3)
  occurredAt    DateTime                     @default(now())
  note          String?
  actorId       String?

  rawMaterial RawMaterial         @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  batch       RawMaterialBatch    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  receipt     RawMaterialReceipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  actor       User?               @relation("StockMovementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([rawMaterialId, occurredAt])
  @@index([batchId])
  @@index([receiptId])
  @@index([type])
  @@index([actorId])
}

model MaterialRequest {
  id                String                @id @default(cuid())
  rawMaterialId     String
  requestedQuantity Decimal               @db.Decimal(14, 3)
  issuedQuantity    Decimal               @default(0) @db.Decimal(14, 3)
  status            MaterialRequestStatus @default(PENDING)
  neededBy          DateTime?
  notes             String?
  responseNotes     String?
  requestedById     String
  issuedById        String?
  fulfilledAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  rawMaterial               RawMaterial                    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  requestedBy               User                           @relation("MaterialRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  issuedBy                  User?                          @relation("MaterialRequestIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  issues                    MaterialRequestIssue[]
  productionRuns            ProductionRunMaterialRequest[]
  productionMaterialBatches ProductionMaterialStockBatch[]

  @@index([rawMaterialId])
  @@index([requestedById])
  @@index([issuedById])
  @@index([status])
  @@index([createdAt])
}

model MaterialRequestIssue {
  id         String   @id @default(cuid())
  requestId  String
  batchId    String
  quantity   Decimal  @db.Decimal(14, 3)
  issuedById String?
  createdAt  DateTime @default(now())

  request         MaterialRequest               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  batch           RawMaterialBatch              @relation(fields: [batchId], references: [id], onDelete: Restrict)
  issuedBy        User?                         @relation("MaterialRequestIssueIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  productionBatch ProductionMaterialStockBatch?

  @@index([requestId])
  @@index([batchId])
  @@index([issuedById])
}

// --- Phase 4: Production output and Sales finished-goods inventory ---

model ProductionRun {
  id                  String   @id @default(cuid())
  productId           String
  quantityProduced    Int
  // Lower-bound output implied by the recipe and the materials actually used.
  // Null when the product has no active recipe to derive it from.
  expectedQuantity    Int?
  quantityTransferred Int      @default(0)
  wasteQuantity       Int      @default(0)
  producedAt          DateTime
  notes               String?
  createdAt           DateTime @default(now())
  createdById         String?

  product                     Product                           @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy                   User?                             @relation("ProductionRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  materialRequests            ProductionRunMaterialRequest[]
  materialUsages              ProductionRunMaterialUsage[]
  productionMaterialMovements ProductionMaterialStockMovement[]
  waste                       ProductionWaste[]
  salesBatches                SalesProductBatch[]

  @@index([productId, producedAt])
  @@index([createdById])
  @@index([producedAt])
}

model ProductionRunMaterialRequest {
  productionRunId   String
  materialRequestId String
  createdAt         DateTime @default(now())

  productionRun   ProductionRun   @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
  materialRequest MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Restrict)

  @@id([productionRunId, materialRequestId])
  @@index([materialRequestId])
}

model ProductionMaterialStockBatch {
  id                     String   @id @default(cuid())
  rawMaterialId          String
  materialRequestId      String?
  materialRequestIssueId String?  @unique
  storeBatchId           String?
  quantityReceived       Decimal  @db.Decimal(14, 3)
  quantityRemaining      Decimal  @db.Decimal(14, 3)
  receivedAt             DateTime
  createdAt              DateTime @default(now())
  createdById            String?

  rawMaterial          RawMaterial                       @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  materialRequest      MaterialRequest?                  @relation(fields: [materialRequestId], references: [id], onDelete: SetNull)
  materialRequestIssue MaterialRequestIssue?             @relation(fields: [materialRequestIssueId], references: [id], onDelete: SetNull)
  storeBatch           RawMaterialBatch?                 @relation("ProductionStockSourceStoreBatch", fields: [storeBatchId], references: [id], onDelete: SetNull)
  createdBy            User?                             @relation("ProductionMaterialBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  movements            ProductionMaterialStockMovement[]

  @@index([rawMaterialId, receivedAt])
  @@index([materialRequestId])
  @@index([storeBatchId])
  @@index([quantityRemaining])
  @@index([createdById])
}

model ProductionRunMaterialUsage {
  id               String   @id @default(cuid())
  productionRunId  String
  rawMaterialId    String
  expectedQuantity Decimal? @db.Decimal(14, 3)
  actualQuantity   Decimal  @db.Decimal(14, 3)
  createdAt        DateTime @default(now())

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial   @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([productionRunId, rawMaterialId])
  @@index([rawMaterialId])
}

model ProductionMaterialStockMovement {
  id                String                              @id @default(cuid())
  rawMaterialId     String
  productionBatchId String
  productionRunId   String?
  type              ProductionMaterialStockMovementType
  quantity          Decimal                             @db.Decimal(14, 3)
  balanceAfter      Decimal                             @db.Decimal(14, 3)
  occurredAt        DateTime                            @default(now())
  note              String?
  actorId           String?

  rawMaterial     RawMaterial                  @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  productionBatch ProductionMaterialStockBatch @relation(fields: [productionBatchId], references: [id], onDelete: Restrict)
  productionRun   ProductionRun?               @relation(fields: [productionRunId], references: [id], onDelete: SetNull)
  actor           User?                        @relation("ProductionMaterialMovementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([rawMaterialId, occurredAt])
  @@index([productionBatchId])
  @@index([productionRunId])
  @@index([type])
  @@index([actorId])
}

model ProductionWaste {
  id              String              @id @default(cuid())
  productionRunId String?
  productId       String
  type            ProductionWasteType @default(DAMAGED)
  quantity        Int
  reason          String?
  recordedAt      DateTime
  createdAt       DateTime            @default(now())
  createdById     String?

  productionRun ProductionRun? @relation(fields: [productionRunId], references: [id], onDelete: SetNull)
  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy     User?          @relation("ProductionWasteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productionRunId])
  @@index([productId, recordedAt])
  @@index([type])
  @@index([createdById])
}

model SalesProductBatch {
  id                String   @id @default(cuid())
  productId         String
  productionRunId   String?
  batchNumber       Int
  batchDate         DateTime @db.Date
  quantityReceived  Int
  quantityRemaining Int
  receivedAt        DateTime
  notes             String?
  createdAt         DateTime @default(now())
  createdById       String?

  product         Product                     @relation(fields: [productId], references: [id], onDelete: Restrict)
  productionRun   ProductionRun?              @relation(fields: [productionRunId], references: [id], onDelete: SetNull)
  createdBy       User?                       @relation("SalesProductBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  movements       SalesProductStockMovement[]
  saleItemBatches SaleItemBatch[]
  returns         SalesProductReturn[]

  @@unique([productId, batchNumber])
  @@index([productId, batchDate])
  @@index([productionRunId])
  @@index([quantityRemaining])
  @@index([createdById])
}

model SalesProductStockMovement {
  id           String                           @id @default(cuid())
  productId    String
  batchId      String
  type         FinishedProductStockMovementType
  quantity     Int
  balanceAfter Int
  occurredAt   DateTime                         @default(now())
  note         String?
  actorId      String?

  product Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  batch   SalesProductBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  actor   User?             @relation("SalesProductMovementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId, occurredAt])
  @@index([batchId])
  @@index([type])
  @@index([actorId])
}

model Retailer {
  id            String   @id @default(cuid())
  name          String   @unique
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  creditLimit   Decimal  @db.Decimal(14, 2)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?

  createdBy   User?        @relation("RetailerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sales       Sale[]
  posSessions PosSession[]
  payments    RetailerPayment[]

  @@index([isActive])
  @@index([createdById])
}

model RetailerPayment {
  id            String        @id @default(cuid())
  retailerId    String
  amount        Decimal       @db.Decimal(14, 2)
  paymentMethod PaymentMethod
  paidAt        DateTime      @default(now())
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  createdById   String?

  retailer    Retailer                    @relation(fields: [retailerId], references: [id], onDelete: Restrict)
  createdBy   User?                       @relation("RetailerPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  allocations RetailerPaymentAllocation[]

  @@index([retailerId, paidAt])
  @@index([paymentMethod])
  @@index([createdById])
}

model RetailerPaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  saleId    String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  payment RetailerPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  sale    Sale            @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@unique([paymentId, saleId])
  @@index([saleId])
}

model Sale {
  id            String        @id @default(cuid())
  saleNumber    Int           @unique @default(autoincrement())
  customerType  CustomerType   @default(INDIVIDUAL)
  retailerId    String?
  paymentMethod PaymentMethod
  customerName  String?
  soldAt        DateTime
  subtotal      Decimal       @db.Decimal(14, 2)
  discount      Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal       @db.Decimal(14, 2)
  amountPaid    Decimal       @db.Decimal(14, 2)
  balanceDue    Decimal       @default(0) @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime      @default(now())
  createdById   String?

  createdBy  User?       @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  retailer   Retailer?   @relation(fields: [retailerId], references: [id], onDelete: Restrict)
  items      SaleItem[]
  posSession PosSession?
  retailerPaymentAllocations RetailerPaymentAllocation[]

  @@index([soldAt])
  @@index([customerType])
  @@index([retailerId])
  @@index([paymentMethod])
  @@index([createdById])
}

model PosSession {
  id              String           @id @default(cuid())
  displayToken    String           @unique
  terminalId      String?
  status          PosSessionStatus @default(ACTIVE)
  customerType    CustomerType     @default(INDIVIDUAL)
  retailerId      String?
  customerName    String?
  paymentMethod   PaymentMethod    @default(CASH)
  discount        Decimal          @default(0) @db.Decimal(14, 2)
  amountPaid      Decimal?
  notes           String?
  expiresAt       DateTime?
  completedAt     DateTime?
  completedSaleId String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?

  terminal           PosTerminal?     @relation("PosTerminalSessions", fields: [terminalId], references: [id], onDelete: SetNull)
  retailer           Retailer?        @relation(fields: [retailerId], references: [id], onDelete: Restrict)
  currentForTerminal PosTerminal?     @relation("PosTerminalCurrentSession")
  createdBy          User?            @relation("PosSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedSale      Sale?            @relation(fields: [completedSaleId], references: [id], onDelete: SetNull)
  items              PosSessionItem[]

  @@index([status])
  @@index([terminalId])
  @@index([customerType])
  @@index([retailerId])
  @@index([createdById])
  @@index([createdAt])
}

model PosTerminal {
  id               String   @id @default(cuid())
  name             String?
  displayToken     String   @unique
  currentSessionId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      String?

  createdBy      User?        @relation("PosTerminalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  currentSession PosSession?  @relation("PosTerminalCurrentSession", fields: [currentSessionId], references: [id], onDelete: SetNull)
  sessions       PosSession[] @relation("PosTerminalSessions")

  @@index([createdById])
  @@index([createdAt])
}

model PosSessionItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session PosSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([sessionId, productId])
  @@index([productId])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(14, 2)
  lineTotal Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  sale        Sale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  batchIssues SaleItemBatch[]
  returns     SalesProductReturn[]

  @@index([saleId])
  @@index([productId])
}

model SaleItemBatch {
  id         String   @id @default(cuid())
  saleItemId String
  batchId    String
  quantity   Int
  createdAt  DateTime @default(now())

  saleItem SaleItem          @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batch    SalesProductBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([saleItemId])
  @@index([batchId])
}

model SalesProductReturn {
  id          String                 @id @default(cuid())
  saleItemId  String?
  productId   String
  batchId     String?
  disposition SalesReturnDisposition
  quantity    Int
  reason      String?
  recordedAt  DateTime
  createdAt   DateTime               @default(now())
  createdById String?

  saleItem  SaleItem?          @relation(fields: [saleItemId], references: [id], onDelete: SetNull)
  product   Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  batch     SalesProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdBy User?              @relation("SalesReturnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([saleItemId])
  @@index([productId, recordedAt])
  @@index([batchId])
  @@index([disposition])
  @@index([createdById])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  actorId    String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
