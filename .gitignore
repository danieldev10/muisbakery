# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
apps/*/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing output (test source remains version-controlled)
**/coverage/
**/.nyc_output/
**/blob-report/
**/playwright-report/
**/test-results/
**/playwright/.auth/
junit*.xml

# next.js
**/.next/
**/out/

# compiled output
**/build/
**/dist/

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
~$*.docx
~$*.xlsx
~$*.pptx

# logs and runtime files
*.log
logs/
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local databases and backups
*.db
*.db-*
*.sqlite
*.sqlite-*
*.sqlite3
*.sqlite3-*
*.dump
*.backup
*.bak
*.agekey
*.dump.age
*.dump.age.sha256

# environment files; sanitized templates may be committed
.env
.env.*
!.env.example
!.env.*.example

# vercel
.vercel/

# caches
*.tsbuildinfo
next-env.d.ts
.cache/
.turbo/
.eslintcache
.stylelintcache
.parcel-cache/

# editor state
.idea/
.vscode/
*.swp
*.swo
*~

AGENTS.md
CLAUDE.md
/.claude/
/awesome-design-md
/tmp
