# Run this bridge on the cashier computer that owns the receipt printer.
PRINT_BRIDGE_HOST=127.0.0.1
PRINT_BRIDGE_PORT=18181
PRINT_BRIDGE_TOKEN=replace-with-a-long-random-token
PRINT_BRIDGE_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.15:3000

# USB printer already installed in macOS/Linux: use its `lpstat -p` queue name.
PRINT_BRIDGE_TARGET=cups
THERMAL_PRINTER_QUEUE=Muis_Bakery_Receipt_Printer

# Network printer alternative. Uncomment these and set PRINT_BRIDGE_TARGET=tcp.
# PRINT_BRIDGE_TARGET=tcp
# THERMAL_PRINTER_HOST=192.168.1.50
# THERMAL_PRINTER_PORT=9100
