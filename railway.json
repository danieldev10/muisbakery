{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway"
  },
  "deploy": {
    "preDeployCommand": [
      "npm run prisma:deploy -w @muisbakery/api"
    ],
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  }
}
