# Muis Bakery local/Docker configuration
# Copy this file once with: cp .env.example .env
# Keep .env private and never commit its real credentials.

# Local/LAN addresses and ports
# Set PUBLIC_HOST to the server's stable LAN IP or Tailscale hostname.
# PUBLIC_HOST=192.168.1.15
WEB_HOST_PORT=3000
API_HOST_PORT=3001
POSTGRES_HOST_PORT=5433

# First-run database mode: bootstrap, demo, or none
SEED_MODE=bootstrap
SEED_ADMIN_EMAIL=admin@muisbakery.local
SEED_ADMIN_NAME=Muis Bakery Admin
# Leave blank to generate a one-time password in `docker compose logs setup`.
SEED_ADMIN_PASSWORD=

# Replace these before live bakery operation.
AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
INTERNAL_API_SECRET=replace-with-another-32-character-random-secret
POSTGRES_PASSWORD=replace-with-a-strong-url-safe-password

# Receipt identity
RECEIPT_BUSINESS_NAME=Muis Bakery
RECEIPT_BUSINESS_ADDRESS=
RECEIPT_BUSINESS_PHONE=
RECEIPT_RETURN_POLICY=Please retain this receipt for returns.

# Optional direct ESC/POS printing
# Run `npm run print-bridge` on the computer connected to the printer.
# Uncomment the URL only after the bridge is configured and running.
# RECEIPT_PRINT_BRIDGE_URL=http://127.0.0.1:18181
PRINT_BRIDGE_HOST=127.0.0.1
PRINT_BRIDGE_PORT=18181
PRINT_BRIDGE_TOKEN=replace-with-a-long-random-token
PRINT_BRIDGE_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.15:3000,https://muisfoods.vercel.app

# USB printer installed in macOS/Linux. Use the queue from `lpstat -p`.
PRINT_BRIDGE_TARGET=cups
THERMAL_PRINTER_QUEUE=Muis_Bakery_Receipt_Printer

# Network ESC/POS printer alternative:
# PRINT_BRIDGE_TARGET=tcp
# THERMAL_PRINTER_HOST=192.168.1.50
# THERMAL_PRINTER_PORT=9100

# Optional encrypted off-site database backups to Supabase Storage
# Leave COMPOSE_PROFILES unset until every backup setting is complete.
# COMPOSE_PROFILES=backup
# SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=YOUR_SUPABASE_S3_REGION
# SUPABASE_S3_ACCESS_KEY_ID=YOUR_SERVER_SIDE_S3_ACCESS_KEY
# SUPABASE_S3_SECRET_ACCESS_KEY=YOUR_SERVER_SIDE_S3_SECRET_KEY
# SUPABASE_STORAGE_BUCKET=muisbakery-database-backups
# BACKUP_AGE_RECIPIENT=age1YOUR_PUBLIC_RECIPIENT
# BACKUP_PREFIX=database
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_RETRY_SECONDS=900
# BACKUP_LOCAL_RETENTION_DAYS=7
# BACKUP_TIMEZONE=Africa/Lagos
